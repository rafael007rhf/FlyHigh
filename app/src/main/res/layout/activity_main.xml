<?xml version="1.0" encoding="utf-8"?>
<!-- FlyHigh - Tela principal (Wear OS) -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/flyhigh_bg">

    <!-- Silhueta de fundo: corredor + skyline -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.6"
        android:src="@drawable/bg_skyline_runner"
        android:importantForAccessibility="no" />

    <!-- Conteudo centralizado -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="6dp"
        android:paddingEnd="20dp"
        android:paddingBottom="6dp">

        <!-- Barra de status: pin + sinal (esq) / coracao (dir) -->

        <!-- Marca: FlyHigh + asa -->

        <!-- Slogan -->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:text="@string/brand_fly"
                android:textColor="@color/flyhigh_white"
                android:textSize="25sp"
                android:textStyle="bold|italic" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:text="@string/brand_high"
                android:textColor="@color/flyhigh_yellow"
                android:textSize="25sp"
                android:textStyle="bold|italic" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="2dp"
                android:layout_marginBottom="6dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_wing" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="1dp"
            android:layout_marginBottom="10dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.18"
            android:text="@string/tagline"
            android:textColor="@color/flyhigh_dim"
            android:textSize="9sp" />

        <!-- Botao Play central -->
        <ImageView
            android:id="@+id/btnPlayPause"
            android:layout_width="78dp"
            android:layout_height="78dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_play_circle"
            android:clickable="true"
            android:contentDescription="@string/cd_play"
            android:focusable="true"
            android:padding="26dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_play" />

        <!-- Botao Perfil -->
        <Button
            android:id="@+id/btnPerfil"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_metric_card"
            android:letterSpacing="0.12"
            android:paddingStart="14dp"
            android:paddingTop="5dp"
            android:paddingEnd="14dp"
            android:paddingBottom="5dp"
            android:text="@string/btn_perfil"
            android:textColor="@color/flyhigh_yellow"
            android:textSize="9sp"
            android:textStyle="bold" />

        <!-- Card de metricas -->
    </LinearLayout>
</FrameLayout>
